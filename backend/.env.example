# Copiez ce fichier en ".env" et remplissez votre clé API
# Obtenez votre clé gratuitement (sans carte bancaire) sur : https://developer.tomtom.com/
# 1. Créez un compte sur developer.tomtom.com
# 2. Créez une "App" dans le dashboard
# 3. Copiez la clé API générée automatiquement

TOMTOM_API_KEY=votre_cle_api_ici
PORT=3001
